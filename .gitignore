.DS_Store
__pycache__/
*.pdf
!coding-resource/*.pdf

# Context Preservation System — session-specific runtime data
.claude/context-snapshots/

# D-1: Workflow runtime directories (generated during workflow execution)
verification-logs/
autopilot-logs/
pacs-logs/
review-logs/
diagnosis-logs/
translations/*
!translations/glossary.yaml

# Translation chunking temp directory
.tmp/

# TDD Guard toggle — personal workflow setting (not shared)
.tdd-guard

# Setup Hook logs — runtime diagnostics (regenerated on each run)
.claude/hooks/*.log

# =============================================================================
# GlobalNews Crawling & Analysis System
# =============================================================================

# Python
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
dist/
build/
*.egg

# Data directories (large files, generated at runtime)
data/raw/
data/processed/
data/features/
data/analysis/
data/output/
data/models/
data/logs/

# Keep config files tracked
!data/config/
# Runtime learning state (not version-controlled config)
data/config/bypass_state.json

# Dashboard screenshots (generated by Playwright)
dashboard-*.png

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment
.env
.env.local
.env.production

